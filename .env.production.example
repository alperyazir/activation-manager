# Production ortamı — Supabase Cloud projesinin değerleri
# Cloudflare Pages'te bu iki değişkeni "Environment variables" (Production) altına ekleyin.
# anon key public'tir (frontend'e girer, güvenlidir); service_role ASLA buraya girmez.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>
